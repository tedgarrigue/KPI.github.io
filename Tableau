// ===== DONUTS =====
function donut(svgId,legId,data,colors){
  const svg=document.getElementById(svgId);const leg=document.getElementById(legId);
  const tot=data.reduce((s,d)=>s+d.v,0);const cx=65,cy=65,r=48,sw=16;let cum=-90;
  let paths='',lhtml='';
  data.forEach((item,i)=>{const pct=item.v/tot;const ang=pct*360;const s=cum,e=cum+ang-1.5;cum+=ang;
    const sr=s*Math.PI/180,er=e*Math.PI/180;
    const x1=cx+r*Math.cos(sr),y1=cy+r*Math.sin(sr),x2=cx+r*Math.cos(er),y2=cy+r*Math.sin(er);
    paths+=`<path d="M ${x1} ${y1} A ${r} ${r} 0 ${ang>180?1:0} 1 ${x2} ${y2}" fill="none" stroke="${colors[i%colors.length]}" stroke-width="${sw}" stroke-linecap="round" opacity=".85"/>`;
    lhtml+=`<div class="leg-i"><div class="leg-d" style="background:${colors[i%colors.length]}"></div><span>${item.n}</span><span class="leg-v">${Math.round(pct*100)}%</span></div>`});
  paths+=`<text x="${cx}" y="${cy-1}" text-anchor="middle" fill="#e4e8f1" font-family="Space Mono,monospace" font-size="14" font-weight="700">${fmt(tot)}</text>`;
  paths+=`<text x="${cx}" y="${cy+12}" text-anchor="middle" fill="#525d73" font-family="DM Sans,sans-serif" font-size="9">visites</text>`;
  svg.innerHTML=paths;leg.innerHTML=lhtml;
}

