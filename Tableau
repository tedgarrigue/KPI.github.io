<style>
:root {
  --bg: #07090f; --bg2: #0d1117; --card: #131922; --card-h: #1a2233;
  --bdr: #1c2536; --t1: #e4e8f1; --t2: #8b95aa; --t3: #525d73;
  --blue: #4a8eff; --cyan: #22d3ee; --green: #10b981; --amber: #f59e0b;
  --rose: #f43f5e; --violet: #a78bfa; --orange: #fb923c; --pink: #ec4899;
  --r: 14px;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--t1);min-height:100vh}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 60% 40% at 20% 10%,rgba(74,142,255,.06),transparent),radial-gradient(ellipse 50% 50% at 80% 80%,rgba(34,211,238,.04),transparent);pointer-events:none}
.app{position:relative;z-index:1}

.header{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--bdr);background:rgba(13,17,23,.85);backdrop-filter:blur(20px);position:sticky;top:0;z-index:100;flex-wrap:wrap;gap:10px}
.header-left{display:flex;align-items:center;gap:12px}
.logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#4a8eff,#22d3ee);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:#fff;box-shadow:0 0 24px rgba(74,142,255,.3)}
.header-title{font-size:16px;font-weight:700}
.header-title span{color:var(--t3);font-weight:400;margin-left:6px;font-size:12px}

.nav{display:flex;gap:2px;background:var(--card);border-radius:8px;padding:3px}
.nav button{padding:6px 12px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;color:var(--t3);border:none;background:none;font-family:inherit;transition:all .2s}
.nav button.active{background:var(--blue);color:#fff}
.nav button:hover:not(.active){color:var(--t1)}

.main{padding:20px 24px;max-width:1480px;margin:0 auto}
.section-title{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--t3);margin:24px 0 12px;display:flex;align-items:center;gap:8px}
.section-title::before{content:'';width:3px;height:14px;border-radius:2px;background:var(--blue)}

.g{display:grid;gap:14px;margin-bottom:14px}
.g2{grid-template-columns:1fr 1fr}
.g3{grid-template-columns:1fr 1fr 1fr}
.g4{grid-template-columns:repeat(4,1fr)}
.g5{grid-template-columns:repeat(5,1fr)}
.g23{grid-template-columns:2fr 3fr}
.g32{grid-template-columns:3fr 2fr}

.card{background:var(--card);border:1px solid var(--bdr);border-radius:var(--r);padding:18px;transition:border-color .3s}
.card:hover{border-color:#2a3a55}
.card-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.card-t{font-size:13px;font-weight:600}
.badge{font-size:10px;padding:4px 10px;border-radius:16px;font-weight:600;letter-spacing:.3px}
.badge-b{background:rgba(74,142,255,.12);color:var(--blue)}
.badge-g{background:rgba(16,185,129,.12);color:var(--green)}
.badge-r{background:rgba(244,63,94,.12);color:var(--rose)}
.badge-a{background:rgba(245,158,11,.12);color:var(--amber)}

/* KPI */
.kpi{padding:16px 18px;position:relative;overflow:hidden}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kpi:nth-child(1)::after{background:linear-gradient(90deg,var(--blue),var(--cyan))}
.kpi:nth-child(2)::after{background:linear-gradient(90deg,var(--cyan),var(--green))}
.kpi:nth-child(3)::after{background:linear-gradient(90deg,var(--green),#34d399)}
.kpi:nth-child(4)::after{background:linear-gradient(90deg,var(--amber),var(--orange))}
.kpi:nth-child(5)::after{background:linear-gradient(90deg,var(--rose),var(--pink))}
.kpi-l{font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:6px}
.kpi-v{font-size:24px;font-weight:700;letter-spacing:-1px;font-family:'Space Mono',monospace}
.kpi:nth-child(1) .kpi-v{color:var(--blue)}
.kpi:nth-child(2) .kpi-v{color:var(--cyan)}
.kpi:nth-child(3) .kpi-v{color:var(--green)}
.kpi:nth-child(4) .kpi-v{color:var(--amber)}
.kpi:nth-child(5) .kpi-v{color:var(--rose)}
.kpi-s{font-size:10px;color:var(--t3);margin-top:3px}
.up{color:var(--green);font-weight:600} .dn{color:var(--rose);font-weight:600}
.target{font-size:9px;padding:2px 6px;border-radius:10px;margin-top:6px;display:inline-block}
.target-ok{background:rgba(16,185,129,.1);color:var(--green)}
.target-warn{background:rgba(245,158,11,.1);color:var(--amber)}
.target-bad{background:rgba(244,63,94,.1);color:var(--rose)}

/* Tables */
table{width:100%;border-collapse:collapse}
th{text-align:left;font-size:9px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;padding:6px 8px;border-bottom:1px solid var(--bdr)}
td{padding:7px 8px;font-size:11px;border-bottom:1px solid rgba(28,37,54,.5)}
tr:hover td{background:rgba(74,142,255,.03)}
.mono{font-family:'Space Mono',monospace;font-size:11px}

.bar-c{position:relative;padding-right:60px!important}
.mb{height:4px;border-radius:2px;background:var(--blue);transition:width .8s ease}
.bv{position:absolute;right:8px;top:50%;transform:translateY(-50%);font-family:'Space Mono',monospace;font-size:10px;color:var(--t2)}

.scroll{max-height:320px;overflow-y:auto}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:2px}

/* Chart */
canvas{width:100%!important}

/* Bars */
.hbar{display:flex;align-items:center;gap:8px;padding:4px 0}
.hbar-l{font-size:11px;width:150px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hbar-w{flex:1;height:5px;background:rgba(74,142,255,.06);border-radius:3px}
.hbar-b{height:100%;border-radius:3px;transition:width .8s ease}
.hbar-v{font-family:'Space Mono',monospace;font-size:10px;color:var(--t2);width:50px;text-align:right;flex-shrink:0}

/* Donut */
.donut-w{display:flex;align-items:center;gap:16px}
.donut-leg{display:flex;flex-direction:column;gap:6px;flex:1}
.leg-i{display:flex;align-items:center;gap:6px;font-size:11px}
.leg-d{width:8px;height:8px;border-radius:3px;flex-shrink:0}
.leg-v{margin-left:auto;font-family:'Space Mono',monospace;font-size:10px;color:var(--t2)}

/* Engagement compare */
.eng-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.eng-box{text-align:center;padding:14px;border-radius:10px;border:1px solid var(--bdr)}
.eng-box h4{font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--t3);margin-bottom:8px}
.eng-val{font-size:20px;font-weight:700;font-family:'Space Mono',monospace}
.eng-sub{font-size:10px;color:var(--t3);margin-top:2px}

/* LinkedIn */
.li-stat{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(28,37,54,.3)}
.li-stat:last-child{border:none}
.li-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.li-info{flex:1}
.li-info .label{font-size:11px;color:var(--t2)}
.li-info .val{font-size:16px;font-weight:700;font-family:'Space Mono',monospace}

/* Persona */
.persona{display:flex;gap:14px;align-items:flex-start}
.persona-avatar{width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,var(--blue),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0}
.persona-facts{display:flex;flex-direction:column;gap:6px}
.persona-fact{display:flex;align-items:center;gap:8px;font-size:12px}
.persona-fact .icon{width:20px;text-align:center}

@media(max-width:1100px){.g3,.g4,.g5{grid-template-columns:1fr 1fr}.g23,.g32{grid-template-columns:1fr}}
@media(max-width:700px){.g2,.g3,.g4,.g5{grid-template-columns:1fr}.main{padding:14px}.header{padding:12px}}

.fade{opacity:0;transform:translateY(8px);animation:fi .4s forwards}
@keyframes fi{to{opacity:1;transform:translateY(0)}}
</style>
</head>
