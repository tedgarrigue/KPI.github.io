  const bw=cW/12*.55,gap=cW/12;
  li2024.impressions.forEach((v,i)=>{const x=pad.left+gap*i+gap/2-bw/2;const h=(v/mx)*cH;const y=pad.top+cH-h;
    const g=ctx.createLinearGradient(0,y,0,pad.top+cH);g.addColorStop(0,'#0077B5');g.addColorStop(1,'rgba(0,119,181,.2)');
    ctx.fillStyle=g;ctx.beginPath();ctx.roundRect(x,y,bw,h,3);ctx.fill();
    ctx.fillStyle='#525d73';ctx.fillText(M[i],x+bw/2,H-10)});
  ctx.fillStyle='#8b95aa';ctx.font='10px "DM Sans"';ctx.textAlign='left';ctx.fillText('Impressions mensuelles',pad.left,pad.top-4)
}
function renderLiTable(){
  document.getElementById('liTable').innerHTML='<table><thead><tr><th>Mois</th><th>Posts</th><th>Impr.</th><th>Clics</th><th>Likes</th><th>Eng.%</th></tr></thead><tbody>'+
    li2024.months.map((m,i)=>`<tr><td>${M[i]}</td><td class="mono">${li2024.posts[i]}</td><td class="mono">${fmt(li2024.impressions[i])}</td><td class="mono">${fmt(li2024.clicks[i])}</td><td class="mono">${li2024.likes[i]}</td><td class="mono">${li2024.engRate[i].toFixed(1)}%</td></tr>`).join('')+'</tbody></table>'
}
function renderLiFollowers(){
  const canvas=document.getElementById('liFollowers');const ctx=canvas.getContext('2d');
  const dpr=window.devicePixelRatio||1;const rect=canvas.parentElement.getBoundingClientRect();
  canvas.width=rect.width*dpr;canvas.height=200*dpr;canvas.style.height='200px';ctx.scale(dpr,dpr);
  const W=rect.width,H=200,pad={top:16,right:12,bottom:32,left:44};
  const cW=W-pad.left-pad.right,cH=H-pad.top-pad.bottom;ctx.clearRect(0,0,W,H);
  const data=li2024.followers;const mn=Math.min(...data)*.98,mx=Math.max(...data)*1.02;
  const pts=data.map((v,i)=>({x:pad.left+(cW/11)*i,y:pad.top+cH-((v-mn)/(mx-mn))*cH}));
  ctx.beginPath();ctx.moveTo(pts[0].x,pad.top+cH);pts.forEach(p=>ctx.lineTo(p.x,p.y));ctx.lineTo(pts[11].x,pad.top+cH);ctx.closePath();
  const g=ctx.createLinearGradient(0,pad.top,0,pad.top+cH);g.addColorStop(0,'rgba(0,119,181,.15)');g.addColorStop(1,'transparent');ctx.fillStyle=g;ctx.fill();
  ctx.beginPath();ctx.strokeStyle='#0077B5';ctx.lineWidth=2;pts.forEach((p,i)=>i?ctx.lineTo(p.x,p.y):ctx.moveTo(p.x,p.y));ctx.stroke();
  pts.forEach(p=>{ctx.beginPath();ctx.arc(p.x,p.y,2.5,0,Math.PI*2);ctx.fillStyle='#0077B5';ctx.fill()});
  ctx.textAlign='center';ctx.font='9px "DM Sans"';ctx.fillStyle='#525d73';
  for(let i=0;i<12;i++)ctx.fillText(M[i],pad.left+(cW/11)*i,H-10)
}
function renderLiImprPost(){
  const canvas=document.getElementById('liImprPost');const ctx=canvas.getContext('2d');
  const dpr=window.devicePixelRatio||1;const rect=canvas.parentElement.getBoundingClientRect();
  canvas.width=rect.width*dpr;canvas.height=200*dpr;canvas.style.height='200px';ctx.scale(dpr,dpr);
  const W=rect.width,H=200,pad={top:16,right:12,bottom:32,left:44};
  const cW=W-pad.left-pad.right,cH=H-pad.top-pad.bottom;ctx.clearRect(0,0,W,H);
  const data=li2024.imprMoy;const mx=Math.max(...data)*1.1;
  const bw=cW/12*.5,gap=cW/12;
  data.forEach((v,i)=>{const x=pad.left+gap*i+gap/2-bw/2;const h=(v/mx)*cH;const y=pad.top+cH-h;
    ctx.fillStyle=v>3000?'#f59e0b':'#0077B5';ctx.beginPath();ctx.roundRect(x,y,bw,h,2);ctx.fill()});
  ctx.textAlign='center';ctx.font='9px "DM Sans"';ctx.fillStyle='#525d73';
  for(let i=0;i<12;i++)ctx.fillText(M[i],pad.left+(cW/12)*i+cW/24,H-10)
}

