function renderMonthChart(){
  const data=monthly[selYear];if(!data)return;
  const canvas=document.getElementById('monthChart');const ctx=canvas.getContext('2d');
  const dpr=window.devicePixelRatio||1;const rect=canvas.parentElement.getBoundingClientRect();
  canvas.width=rect.width*dpr;canvas.height=280*dpr;canvas.style.height='280px';ctx.scale(dpr,dpr);
  const W=rect.width,H=280,pad={top:24,right:16,bottom:40,left:55};
  const cW=W-pad.left-pad.right,cH=H-pad.top-pad.bottom;
  ctx.clearRect(0,0,W,H);

  const ses=data.sessions.filter(v=>v!=null);const uni=data.uniques.filter(v=>v!=null);
  const cnt=ses.length;if(!cnt)return;
  const maxV=Math.max(...ses)*1.12;

  for(let i=0;i<=4;i++){const y=pad.top+(cH/4)*i;const val=maxV-(maxV/4)*i;
    ctx.strokeStyle='rgba(28,37,54,.6)';ctx.lineWidth=1;ctx.setLineDash([3,3]);
    ctx.beginPath();ctx.moveTo(pad.left,y);ctx.lineTo(W-pad.right,y);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='#525d73';ctx.font='10px "Space Mono",monospace';ctx.textAlign='right';ctx.fillText(fmt(Math.round(val)),pad.left-6,y+3)}

  ctx.textAlign='center';ctx.fillStyle='#525d73';ctx.font='10px "DM Sans"';
  for(let i=0;i<cnt;i++){ctx.fillText(M[i],pad.left+(cW/(cnt-1||1))*i,H-12)}

  function drawL(arr,col,fill){
    const pts=arr.map((v,i)=>({x:pad.left+(cW/(arr.length-1||1))*i,y:pad.top+cH-(v/maxV)*cH}));
    ctx.beginPath();ctx.moveTo(pts[0].x,pad.top+cH);pts.forEach(p=>ctx.lineTo(p.x,p.y));
    ctx.lineTo(pts[pts.length-1].x,pad.top+cH);ctx.closePath();
    const g=ctx.createLinearGradient(0,pad.top,0,pad.top+cH);g.addColorStop(0,fill);g.addColorStop(1,'transparent');
    ctx.fillStyle=g;ctx.fill();
    ctx.beginPath();ctx.strokeStyle=col;ctx.lineWidth=2.5;ctx.lineJoin='round';
    pts.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y));ctx.stroke();
    pts.forEach(p=>{ctx.beginPath();ctx.arc(p.x,p.y,3,0,Math.PI*2);ctx.fillStyle=col;ctx.fill();
      ctx.beginPath();ctx.arc(p.x,p.y,1.2,0,Math.PI*2);ctx.fillStyle='#07090f';ctx.fill()})
  }
  drawL(uni,'#22d3ee','rgba(34,211,238,.08)');drawL(ses,'#4a8eff','rgba(74,142,255,.1)');

  ctx.font='11px "DM Sans"';const lx=W-pad.right-170;
  ctx.fillStyle='#4a8eff';ctx.beginPath();ctx.arc(lx,pad.top+4,3.5,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#8b95aa';ctx.textAlign='left';ctx.fillText('Sessions',lx+8,pad.top+8);
  ctx.fillStyle='#22d3ee';ctx.beginPath();ctx.arc(lx+80,pad.top+4,3.5,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#8b95aa';ctx.fillText('Uniques',lx+88,pad.top+8);
}

