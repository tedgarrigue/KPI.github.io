# Job Provider Configuration
# ============================

# Data provider: 'mock' | 'multi' | 'adzuna' | 'indeed' | 'jooble' | 'remoteok'
# 'multi' = search across all configured providers
NEXT_PUBLIC_JOB_PROVIDER=mock

# Adzuna API (https://adzuna.com/api)
NEXT_PUBLIC_ADZUNA_API_KEY=your_adzuna_key_here
NEXT_PUBLIC_ADZUNA_APP_ID=your_adzuna_app_id_here

# Indeed API (via RapidAPI: https://rapidapi.com/laimoon/api/indeed-api)
# Note: Requires RapidAPI subscription (free tier available)
NEXT_PUBLIC_INDEED_API_KEY=your_indeed_rapidapi_key_here

# Jooble API (https://jooble.org/api)
NEXT_PUBLIC_JOOBLE_API_KEY=your_jooble_key_here

# RemoteOK (FREE - no key required)
# RemoteOK doesn't require authentication for public job search

# Environment
NODE_ENV=development

