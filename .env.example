# Job Provider Configuration
# ============================

# Data provider: 'mock' | 'adzuna' | 'jooble' | 'francetravail'
NEXT_PUBLIC_JOB_PROVIDER=mock

# Adzuna API (https://adzuna.com/api)
NEXT_PUBLIC_ADZUNA_API_KEY=your_adzuna_key_here
NEXT_PUBLIC_ADZUNA_APP_ID=your_adzuna_app_id_here

# Jooble API (https://jooble.org/api)
NEXT_PUBLIC_JOOBLE_API_KEY=your_jooble_key_here

# France Travail API (requires OAuth2 - not implemented yet)
# NEXT_PUBLIC_FRANCE_TRAVAIL_CLIENT_ID=your_client_id_here
# NEXT_PUBLIC_FRANCE_TRAVAIL_CLIENT_SECRET=your_secret_here

# Environment
NODE_ENV=development
